{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://shared-intake-governance.local/schemas/provider-result.schema.json",
  "title": "ProviderResult",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "run_id",
    "result_id",
    "request_id",
    "provider",
    "recorded_by",
    "recorded_at",
    "result_status",
    "summary",
    "provider_request_path",
    "mediation_id",
    "intent_id",
    "profile_id",
    "action_class",
    "tool_name",
    "response_refs",
    "usage_metadata",
    "error",
    "evidence_refs"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "provider-result.v1"
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "result_id": {
      "type": "string",
      "minLength": 1
    },
    "request_id": {
      "type": "string",
      "minLength": 1
    },
    "provider": {
      "type": "string",
      "enum": [
        "claude",
        "gemini",
        "vibe"
      ]
    },
    "recorded_by": {
      "type": "string",
      "minLength": 1
    },
    "recorded_at": {
      "type": "string",
      "format": "date-time"
    },
    "result_status": {
      "type": "string",
      "enum": [
        "succeeded",
        "failed",
        "blocked"
      ]
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "provider_request_path": {
      "type": "string",
      "minLength": 1
    },
    "mediation_id": {
      "type": "string",
      "minLength": 1
    },
    "intent_id": {
      "type": "string",
      "minLength": 1
    },
    "profile_id": {
      "type": "string",
      "minLength": 1
    },
    "action_class": {
      "type": "string",
      "enum": [
        "read_only",
        "edit_local",
        "destructive_local",
        "external_side_effect",
        "credentialed_remote"
      ]
    },
    "tool_name": {
      "type": "string",
      "minLength": 1
    },
    "response_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "usage_metadata": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "error": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "kind",
            "message"
          ],
          "properties": {
            "kind": {
              "type": "string",
              "minLength": 1
            },
            "message": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      ]
    },
    "evidence_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
