{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://shared-intake-governance.local/schemas/source-config.schema.json",
  "title": "SourceConfig",
  "oneOf": [
    {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "source_type",
        "source_id",
        "owner",
        "repo"
      ],
      "properties": {
        "schema_version": {
          "type": "string",
          "const": "source-config.v1"
        },
        "source_type": {
          "type": "string",
          "const": "github_repo"
        },
        "source_id": {
          "type": "string",
          "minLength": 1
        },
        "owner": {
          "type": "string",
          "minLength": 1
        },
        "repo": {
          "type": "string",
          "minLength": 1
        },
        "api_base_url": {
          "type": "string",
          "format": "uri"
        }
      }
    },
    {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "source_type",
        "source_id",
        "keywords",
        "max_results"
      ],
      "properties": {
        "schema_version": {
          "type": "string",
          "const": "source-config.v1"
        },
        "source_type": {
          "type": "string",
          "const": "arxiv_rss_keywords"
        },
        "source_id": {
          "type": "string",
          "minLength": 1
        },
        "keywords": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "max_results": {
          "type": "integer",
          "minimum": 1,
          "maximum": 100
        },
        "api_base_url": {
          "type": "string",
          "format": "uri"
        }
      }
    },
    {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "source_type",
        "source_id",
        "feed_url"
      ],
      "properties": {
        "schema_version": {
          "type": "string",
          "const": "source-config.v1"
        },
        "source_type": {
          "type": "string",
          "const": "rss"
        },
        "source_id": {
          "type": "string",
          "minLength": 1
        },
        "feed_url": {
          "type": "string",
          "format": "uri"
        },
        "source_trust": {
          "type": "string",
          "enum": [
            "official",
            "maintainer",
            "platform",
            "secondary",
            "social",
            "unknown"
          ]
        }
      }
    }
  ]
}
