{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://shared-intake-governance.local/schemas/provider-request.schema.json",
  "title": "ProviderRequest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "run_id",
    "request_id",
    "prepared_at",
    "provider",
    "mediation_record_path",
    "mediation_id",
    "intent_id",
    "profile_id",
    "action_class",
    "tool_name",
    "policy_decision",
    "mediation_decision",
    "capabilities",
    "context_refs",
    "evidence_refs"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "provider-request.v1"
    },
    "run_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
    },
    "request_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
    },
    "prepared_at": {
      "type": "string",
      "format": "date-time"
    },
    "provider": {
      "type": "string",
      "enum": [
        "claude",
        "gemini",
        "vibe"
      ]
    },
    "mediation_record_path": {
      "type": "string",
      "minLength": 1
    },
    "mediation_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
    },
    "intent_id": {
      "type": "string",
      "description": "Tool intent logical correlation id. It is not a runtime path segment in the current contracts.",
      "minLength": 1
    },
    "profile_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
    },
    "action_class": {
      "type": "string",
      "enum": [
        "read_only"
      ]
    },
    "tool_name": {
      "type": "string",
      "minLength": 1
    },
    "policy_decision": {
      "type": "string",
      "enum": [
        "allowed",
        "gated",
        "denied"
      ]
    },
    "mediation_decision": {
      "type": "string",
      "const": "ready"
    },
    "capabilities": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "read_only"
        ]
      }
    },
    "context_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "evidence_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
