{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://shared-intake-governance.local/schemas/governance-audit-event.schema.json",
  "title": "GovernanceAuditEvent",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "run_id",
    "event_type",
    "recorded_at",
    "intent_id",
    "profile_id",
    "action_class",
    "tool_name",
    "decision",
    "reason",
    "dry_run_supported",
    "evidence_refs",
    "tool_intent_path"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "governance-audit-event.v1"
    },
    "run_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
    },
    "event_type": {
      "type": "string",
      "const": "tool_intent_evaluated"
    },
    "recorded_at": {
      "type": "string",
      "format": "date-time"
    },
    "intent_id": {
      "type": "string",
      "description": "Tool intent logical correlation id. It is not a runtime path segment in the current contracts.",
      "minLength": 1
    },
    "profile_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
    },
    "action_class": {
      "type": "string",
      "enum": [
        "read_only",
        "edit_local",
        "destructive_local",
        "external_side_effect",
        "credentialed_remote"
      ]
    },
    "tool_name": {
      "type": "string",
      "minLength": 1
    },
    "decision": {
      "type": "string",
      "enum": [
        "allowed",
        "gated",
        "denied"
      ]
    },
    "reason": {
      "type": "string",
      "minLength": 1
    },
    "dry_run_supported": {
      "type": "boolean"
    },
    "evidence_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "tool_intent_path": {
      "type": "string",
      "minLength": 1
    }
  }
}
