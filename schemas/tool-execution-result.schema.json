{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://shared-intake-governance.local/schemas/tool-execution-result.schema.json",
  "title": "ToolExecutionResult",
  "type": "object",
  "additionalProperties": false,
  "allOf": [
    {
      "if": {
        "properties": {
          "execution_status": {
            "const": "succeeded"
          }
        },
        "required": [
          "execution_status"
        ]
      },
      "then": {
        "properties": {
          "error": {
            "type": "null"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "execution_status": {
            "enum": [
              "failed",
              "blocked"
            ]
          }
        },
        "required": [
          "execution_status"
        ]
      },
      "then": {
        "properties": {
          "error": {
            "type": "object"
          }
        }
      }
    }
  ],
  "required": [
    "schema_version",
    "run_id",
    "execution_id",
    "intent_id",
    "profile_id",
    "action_class",
    "tool_name",
    "executed_by",
    "executed_at",
    "execution_status",
    "summary",
    "tool_intent_path",
    "mediation_record_path",
    "output_refs",
    "execution_metadata",
    "error",
    "evidence_refs"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "tool-execution-result.v1"
    },
    "run_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
    },
    "execution_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
    },
    "intent_id": {
      "type": "string",
      "minLength": 1
    },
    "profile_id": {
      "type": "string",
      "minLength": 1
    },
    "action_class": {
      "type": "string",
      "enum": [
        "read_only",
        "edit_local",
        "destructive_local",
        "external_side_effect",
        "credentialed_remote"
      ]
    },
    "tool_name": {
      "type": "string",
      "minLength": 1
    },
    "executed_by": {
      "type": "string",
      "minLength": 1
    },
    "executed_at": {
      "type": "string",
      "format": "date-time"
    },
    "execution_status": {
      "type": "string",
      "enum": [
        "succeeded",
        "failed",
        "blocked"
      ]
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "tool_intent_path": {
      "type": "string",
      "minLength": 1
    },
    "mediation_record_path": {
      "type": "string",
      "minLength": 1
    },
    "output_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "execution_metadata": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "error": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "kind",
            "message"
          ],
          "properties": {
            "kind": {
              "type": "string",
              "minLength": 1
            },
            "message": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      ]
    },
    "evidence_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
