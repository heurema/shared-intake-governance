{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://shared-intake-governance.local/schemas/execution-mediation.schema.json",
  "title": "ExecutionMediation",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "run_id",
    "mediation_id",
    "mediated_at",
    "intent_id",
    "profile_id",
    "action_class",
    "tool_name",
    "policy_decision",
    "mediation_decision",
    "reason",
    "dry_run_result_path",
    "approval_record_path",
    "tool_intent_path",
    "evidence_refs"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "execution-mediation.v1"
    },
    "run_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
    },
    "mediation_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
    },
    "mediated_at": {
      "type": "string",
      "format": "date-time"
    },
    "intent_id": {
      "type": "string",
      "description": "Tool intent logical correlation id. It is not a runtime path segment in the current contracts.",
      "minLength": 1
    },
    "profile_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
    },
    "action_class": {
      "type": "string",
      "enum": [
        "read_only",
        "edit_local",
        "destructive_local",
        "external_side_effect",
        "credentialed_remote"
      ]
    },
    "tool_name": {
      "type": "string",
      "minLength": 1
    },
    "policy_decision": {
      "type": "string",
      "enum": [
        "allowed",
        "gated",
        "denied"
      ]
    },
    "mediation_decision": {
      "type": "string",
      "enum": [
        "ready",
        "blocked"
      ]
    },
    "reason": {
      "type": "string",
      "minLength": 1
    },
    "dry_run_result_path": {
      "type": [
        "string",
        "null"
      ]
    },
    "approval_record_path": {
      "type": [
        "string",
        "null"
      ]
    },
    "tool_intent_path": {
      "type": "string",
      "minLength": 1
    },
    "evidence_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
