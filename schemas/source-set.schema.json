{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://shared-intake-governance.local/schemas/source-set.schema.json",
  "title": "SourceSet",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "source_set_id",
    "sources"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "source-set.v1"
    },
    "source_set_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "sources": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "source_id",
          "source_config_path"
        ],
        "properties": {
          "source_id": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
          },
          "source_config_path": {
            "type": "string",
            "pattern": "^sources/examples/[A-Za-z0-9][A-Za-z0-9._-]*\\.json$"
          }
        }
      }
    }
  }
}
