{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://shared-intake-governance.local/schemas/run-manifest.schema.json",
  "title": "RunManifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "run_id",
    "mode",
    "status",
    "started_at",
    "finished_at",
    "runtime_root",
    "raw_root",
    "clean_root",
    "profiles_root",
    "sources",
    "counts",
    "source_health"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "run-manifest.v1"
    },
    "run_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
    },
    "mode": {
      "type": "string",
      "enum": [
        "backfill",
        "daily_collection",
        "shadow",
        "governance"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "started",
        "completed",
        "completed_with_degradation",
        "failed"
      ]
    },
    "started_at": {
      "type": "string",
      "format": "date-time"
    },
    "finished_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "runtime_root": {
      "type": "string",
      "minLength": 1
    },
    "raw_root": {
      "type": "string",
      "minLength": 1
    },
    "clean_root": {
      "type": "string",
      "minLength": 1
    },
    "profiles_root": {
      "type": "string",
      "minLength": 1
    },
    "sources": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
      }
    },
    "counts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "raw_payloads_written",
        "raw_metadata_written",
        "clean_records_written",
        "projected_profiles",
        "quarantined_records",
        "failed_sources"
      ],
      "properties": {
        "raw_payloads_written": {
          "type": "integer",
          "minimum": 0
        },
        "raw_metadata_written": {
          "type": "integer",
          "minimum": 0
        },
        "clean_records_written": {
          "type": "integer",
          "minimum": 0
        },
        "projected_profiles": {
          "type": "integer",
          "minimum": 0
        },
        "quarantined_records": {
          "type": "integer",
          "minimum": 0
        },
        "failed_sources": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "source_health": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
