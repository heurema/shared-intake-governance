{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://shared-intake-governance.local/schemas/approval-record.schema.json",
  "title": "ApprovalRecord",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "run_id",
    "approval_id",
    "intent_id",
    "profile_id",
    "action_class",
    "tool_name",
    "approval_decision",
    "approved_by",
    "approved_at",
    "justification",
    "dry_run_ref",
    "evidence_refs",
    "tool_intent_path"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "approval-record.v1"
    },
    "run_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
    },
    "approval_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
    },
    "intent_id": {
      "type": "string",
      "description": "Tool intent logical correlation id. It is not a runtime path segment in the current contracts.",
      "minLength": 1
    },
    "profile_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
    },
    "action_class": {
      "type": "string",
      "enum": [
        "read_only",
        "edit_local",
        "destructive_local",
        "external_side_effect",
        "credentialed_remote"
      ]
    },
    "tool_name": {
      "type": "string",
      "minLength": 1
    },
    "approval_decision": {
      "type": "string",
      "enum": [
        "approved",
        "rejected"
      ]
    },
    "approved_by": {
      "type": "string",
      "minLength": 1
    },
    "approved_at": {
      "type": "string",
      "format": "date-time"
    },
    "justification": {
      "type": "string",
      "minLength": 1
    },
    "dry_run_ref": {
      "type": [
        "string",
        "null"
      ]
    },
    "evidence_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "tool_intent_path": {
      "type": "string",
      "minLength": 1
    }
  }
}
